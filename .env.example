# Filon · variables d'environnement
# Copier en .env.local et renseigner les valeurs reelles.

# URL HTTP du deploiement Convex (cote client). Fournie par `npx convex dev`.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# URL du site Convex pour le proxy Better Auth (cote client + serveur).
# Generalement l'URL Convex avec le suffixe .site au lieu de .cloud.
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Deploiement Convex actif (auto-renseigne par `npx convex dev`).
CONVEX_DEPLOYMENT=dev:your-deployment

# URL publique du site (base Better Auth + trustedOrigins).
SITE_URL=http://localhost:3000

# Secret Better Auth (a definir cote Convex) :
#   npx convex env set BETTER_AUTH_SECRET $(openssl rand -base64 32)
BETTER_AUTH_SECRET=

# --- PostHog (analytics produit / funnel) ---
# Cle PROJET PostHog (publique, prefixe phc_, region US). Cote client : injectee
# au build par Vite. L'ingestion passe par le proxy meme-origine /api/ph.
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Host de l'UI PostHog (liens toolbar). US par defaut.
VITE_POSTHOG_HOST=https://us.posthog.com
#
# Cote SERVEUR (Convex) — evenements source de verite (conversion, signup,
# activation, parrainage). A poser sur le deploiement Convex, PAS dans ce .env :
#   npx convex env set POSTHOG_PROJECT_KEY phc_xxxxxxxx
#   npx convex env set POSTHOG_HOST https://us.i.posthog.com
# (et en prod : npx convex env set --prod POSTHOG_PROJECT_KEY … + POSTHOG_HOST …)
